# Start i3bar to display a workspace bar (plus the system information i3status
# finds out, if available)

# hacks: status_command i3status --config ~/.config/i3/status.conf
bar {
	height 16
	status_padding 0
	status_edge_padding 0
	output HDMI-A-1
	separator_symbol " |  "
	font pango:Go Mono 11 
	status_command i3blocks -c ~/.config/i3/blocks
}

exec swaymsg focus output HDMI-A-1
